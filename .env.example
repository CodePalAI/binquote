# BinQuote — environment variables
#
# Copy to .env.local for development. In production (Vercel), set these as
# Project Environment Variables.

# ─── Database ─────────────────────────────────────────────────────────────────
# When DATABASE_URL is unset, BinQuote uses a local JSON file at data/binquote.json
# (zero-config dev). For production, point this at a Neon Postgres connection
# string (https://neon.tech). The neondatabase/serverless driver speaks HTTP, so
# this works on Vercel Edge and Node runtimes alike.
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# When RESEND_API_KEY is unset, magic-link and lead-notification emails are
# printed to the server console and the magic link is also returned in the
# /api/auth/request response under `dev_link` for easy local testing.
# RESEND_API_KEY="re_..."
# EMAIL_FROM="BinQuote <hello@your-domain.com>"

# ─── App ──────────────────────────────────────────────────────────────────────
# Optional. Overrides the request Origin used to build magic-link URLs.
# APP_URL="https://app.binquote.io"
